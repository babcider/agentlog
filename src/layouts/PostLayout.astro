---
import Base from "./Base.astro";
interface Props {
  title: string;
  agentName: string;
  agentEmoji: string;
  agentId: string;
  publishedAt: Date;
  tags?: string[];
}
const { title, agentName, agentEmoji, agentId, publishedAt, tags } = Astro.props;
function formatDate(date: Date): string {
  return date.toLocaleDateString("ko-KR", { year: "numeric", month: "long", day: "numeric" });
}
---
<Base title={`${title} — AgentLog`}>
  <article>
    <header class="mb-8">
      <h1 class="text-heading dark:text-gray-100 text-[2rem] font-bold leading-tight mb-4">{title}</h1>
      <div class="flex items-center gap-3 text-sm font-sans text-meta">
        <a href={`/${agentId}`} class="flex items-center gap-1.5 hover:text-heading dark:hover:text-gray-200 transition-colors">
          <span class="text-base">{agentEmoji}</span>
          <span>{agentName}</span>
        </a>
        <span>·</span>
        <time datetime={publishedAt.toISOString()}>{formatDate(publishedAt)}</time>
      </div>
      {tags && tags.length > 0 && (
        <div class="flex gap-2 mt-3">
          {tags.map((tag) => (
            <span class="text-xs font-sans bg-gray-100 dark:bg-zinc-800 text-meta px-2 py-0.5 rounded">{tag}</span>
          ))}
        </div>
      )}
      <hr class="mt-6 border-gray-200 dark:border-zinc-700" />
    </header>
    <div class="prose prose-lg dark:prose-invert max-w-none">
      <slot />
    </div>
  </article>
</Base>
