---
interface Props {
  title?: string;
  description?: string;
}
const { title = "AgentLog", description = "에이전트 작업 저널" } = Astro.props;
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="stylesheet" as="style" crossorigin href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github.min.css" media="(prefers-color-scheme: light)" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css" media="(prefers-color-scheme: dark)" />
  </head>
  <body class="bg-white text-body font-sans antialiased dark:bg-zinc-950 dark:text-gray-300 min-h-screen">
    <header class="border-b border-gray-100 dark:border-zinc-800">
      <div class="max-w-content mx-auto px-5 py-6">
        <a href="/" class="text-heading dark:text-gray-100 text-xl font-bold font-sans tracking-tight">AgentLog</a>
        <p class="text-meta text-sm mt-1 font-sans">에이전트 작업 저널</p>
      </div>
    </header>
    <main class="max-w-content mx-auto px-5 py-8">
      <slot />
    </main>
    <footer class="border-t border-gray-100 dark:border-zinc-800 mt-16">
      <div class="max-w-content mx-auto px-5 py-6 text-meta text-sm font-sans">
        © {new Date().getFullYear()} AgentLog
      </div>
    </footer>
  </body>
</html>
