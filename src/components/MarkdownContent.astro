---
import { renderMarkdown } from "../lib/markdown";
interface Props { content: string; }
const { content } = Astro.props;
const html = renderMarkdown(content);
---
<div class="markdown-body prose prose-stone prose-lg dark:prose-invert max-w-none
  prose-headings:font-semibold
  prose-a:text-blue-600 dark:prose-a:text-blue-400
  prose-code:bg-stone-100 dark:prose-code:bg-zinc-800 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm prose-code:before:content-none prose-code:after:content-none
  prose-pre:bg-stone-900 prose-pre:p-0
  prose-blockquote:not-italic
  prose-table:text-sm
  prose-img:rounded-lg prose-img:mx-auto
  prose-hr:border-stone-200 dark:prose-hr:border-zinc-700"
  set:html={html}
/>

<style is:global>
  /* 코드 블록 래퍼 */
  .code-block-wrapper {
    position: relative;
    margin: 1.5rem 0;
  }
  .code-block-wrapper pre {
    margin: 0 !important;
    border-radius: 0.5rem;
    padding: 1.25rem !important;
  }
  .copy-code-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    background: rgba(255,255,255,0.1);
    border: none;
    border-radius: 0.375rem;
    padding: 0.25rem 0.5rem;
    cursor: pointer;
    font-size: 0.75rem;
    opacity: 0;
    transition: opacity 0.2s;
  }
  .code-block-wrapper:hover .copy-code-btn {
    opacity: 1;
  }
  .copy-code-btn:hover {
    background: rgba(255,255,255,0.2);
  }

  /* 콜아웃 */
  .callout {
    display: flex;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    border-radius: 0.5rem;
    border-left: 4px solid;
    margin: 1.5rem 0;
  }
  .callout-icon {
    font-size: 1.25rem;
    flex-shrink: 0;
    line-height: 1.6;
  }
  .callout-content p {
    margin: 0 !important;
  }
  .callout-content p:first-child {
    font-weight: 600;
  }
  .callout-warning {
    background: #fef9c3;
    border-color: #eab308;
    color: #713f12;
  }
  .callout-tip {
    background: #ecfdf5;
    border-color: #10b981;
    color: #064e3b;
  }
  .callout-success {
    background: #f0fdf4;
    border-color: #22c55e;
    color: #14532d;
  }
  .callout-info {
    background: #eff6ff;
    border-color: #3b82f6;
    color: #1e3a5f;
  }

  /* 다크모드 콜아웃 */
  @media (prefers-color-scheme: dark) {
    .callout-warning {
      background: rgba(234, 179, 8, 0.1);
      border-color: #ca8a04;
      color: #fde68a;
    }
    .callout-tip {
      background: rgba(16, 185, 129, 0.1);
      border-color: #059669;
      color: #a7f3d0;
    }
    .callout-success {
      background: rgba(34, 197, 94, 0.1);
      border-color: #16a34a;
      color: #bbf7d0;
    }
    .callout-info {
      background: rgba(59, 130, 246, 0.1);
      border-color: #2563eb;
      color: #bfdbfe;
    }
  }

  /* 테이블 래퍼 */
  .table-wrapper {
    overflow-x: auto;
    margin: 1.5rem 0;
  }
  .table-wrapper table {
    width: 100%;
    border-collapse: collapse;
  }
  .table-wrapper th {
    background: #f5f5f4;
    font-weight: 600;
    text-align: left;
    padding: 0.625rem 1rem;
    border-bottom: 2px solid #d6d3d1;
    font-size: 0.875rem;
  }
  .table-wrapper td {
    padding: 0.625rem 1rem;
    border-bottom: 1px solid #e7e5e4;
    font-size: 0.875rem;
  }
  @media (prefers-color-scheme: dark) {
    .table-wrapper th {
      background: #27272a;
      border-color: #3f3f46;
    }
    .table-wrapper td {
      border-color: #3f3f46;
    }
  }

  /* 체크리스트 */
  .task-item {
    list-style: none !important;
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    margin-left: -1.5rem;
  }
  .task-item p {
    margin: 0 !important;
  }
  .task-check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.25rem;
    height: 1.25rem;
    border-radius: 0.25rem;
    border: 2px solid #a8a29e;
    flex-shrink: 0;
    margin-top: 0.2rem;
    font-size: 0.7rem;
    font-weight: 700;
  }
  .task-check.checked {
    background: #22c55e;
    border-color: #22c55e;
    color: white;
  }
  .task-done p {
    text-decoration: line-through;
    opacity: 0.6;
  }

  /* HR 스타일 */
  .styled-hr {
    border: none;
    height: 1px;
    background: linear-gradient(to right, transparent, #d6d3d1, transparent);
    margin: 2.5rem 0;
  }
  @media (prefers-color-scheme: dark) {
    .styled-hr {
      background: linear-gradient(to right, transparent, #3f3f46, transparent);
    }
  }

  /* 이미지 캡션 */
  .image-figure {
    text-align: center;
    margin: 2rem 0;
  }
  .image-figure img {
    margin: 0 auto;
    border-radius: 0.5rem;
  }
  .image-figure figcaption {
    font-size: 0.875rem;
    color: #78716c;
    margin-top: 0.5rem;
    font-style: italic;
  }
</style>
